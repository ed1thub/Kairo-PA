# =============================================================================
# Kairo-PA environment variables
# Copy this file to .env.local and fill in every value before running `pnpm dev`.
# See README.md for step-by-step signup instructions for each service.
# Every service below has a free tier sufficient to run Kairo-PA at $0/month.
# =============================================================================

# --- Neon Postgres (Vercel Marketplace: vercel integration add neon) -------
# Relational data + pgvector for RAG. Free tier: 0.5 GB storage.
DATABASE_URL=

# --- Upstash Redis (Vercel Marketplace: vercel integration add upstash/upstash-kv) --
# Short-term memory, rate limiting, idempotency keys. Free tier: 500k commands/mo.
# NOTE: Vercel's Upstash integration provisions these under the legacy
# @vercel/kv-compatible names (KV_*), not UPSTASH_REDIS_REST_*.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Vercel Blob -------------------------------------------------------------
# Uploaded document storage + data exports. Free tier: 1 GB storage.
BLOB_READ_WRITE_TOKEN=

# --- Clerk (Vercel Marketplace, or clerk.com dashboard -> API Keys) --------
# Auth, sessions, MFA. Free tier: 10,000 monthly active users.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/chat
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/chat

# --- Groq (console.groq.com -> API Keys) ------------------------------------
# LLM inference, free tier, serves open-weight models (Llama 3.3, Qwen, etc).
GROQ_API_KEY=
# Any model ID Groq serves. Defaults to llama-3.3-70b-versatile if unset.
# See https://console.groq.com/docs/models for the current list.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (aistudio.google.com -> API Keys) ------------------------
# Free-tier embeddings for RAG document search.
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Tavily (tavily.com -> free API key) -------------------------------------
# Web search tool. Free tier: 1,000 searches/month.
TAVILY_API_KEY=

# --- Google Calendar OAuth (console.cloud.google.com) -----------------------
# Create an OAuth 2.0 Client ID with the Calendar API enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google-calendar/callback

# --- Telegram (message @BotFather to create a bot) --------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# --- App-level ----------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
# 32-byte key for AES-256-GCM encryption of OAuth tokens at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
# Verifies that /api/cron/* routes are only invoked by Vercel Cron.
# Generate with: openssl rand -hex 32
CRON_SECRET=
